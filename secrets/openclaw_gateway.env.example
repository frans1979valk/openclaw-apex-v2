# OpenClaw Gateway — omgevingsvariabelen
# Kopieer naar: secrets/openclaw_gateway.env
# Vul ALLE velden in vóór je docker compose up doet.

# ── Gateway Auth Token ────────────────────────────────────────────────────────
# Genereer met: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=vervang-dit-met-openssl-rand-hex-32

# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-jouw-key-hier

# ── Telegram (NIEUWE bot — aanmaken via @BotFather) ───────────────────────────
# 1. Open Telegram → zoek @BotFather
# 2. Stuur /newbot → kies naam: "OpenClaw Operator" → kies username: openclaw_operator_bot
# 3. Kopieer het token hieronder
TELEGRAM_BOT_TOKEN=1234567890:AAABBBCCCDDDEEEFFFGGGHHHIIIJJJKKK

# Jouw Telegram User ID (alleen jij mag de bot gebruiken)
# Vind je ID via: @userinfobot of @getidsbot in Telegram
TG_ALLOWED_USER_ID=7381250590

# ── Control API verbinding ────────────────────────────────────────────────────
CONTROL_API_URL=http://control_api:8080
CONTROL_API_TOKEN=changeme-strong-token

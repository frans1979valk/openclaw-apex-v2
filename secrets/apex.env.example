TRADING_MODE=demo
EXECUTOR_MODE=blofin_demo
ALLOW_LIVE=false

BLOFIN_API_KEY=your_blofin_api_key_here
BLOFIN_API_SECRET=your_blofin_api_secret_here
BLOFIN_API_PASSPHRASE=your_blofin_passphrase_here

SYMBOL=XRP-USDT
FEE_BPS=6
SLIPPAGE_BPS=2

# CryptoPanic nieuws monitor (gratis key via cryptopanic.com)
CRYPTOPANIC_TOKEN=

# Pre-crash detector drempel (0-100, kopen geblokkeerd boven dit getal)
PRE_CRASH_BUY_BLOCK=60

# Multi-exchange intel (true/false)
EXCHANGE_INTEL_ENABLED=true

# Kimi AI — Moonshot API (https://platform.moonshot.cn)
KIMI_API_KEY=your_moonshot_api_key_here
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-32k

# Control API verbinding
CONTROL_API_URL=http://control_api:8080
CONTROL_API_TOKEN=changeme-strong-token

# Telegram notificaties
TG_BOT_TOKEN_COORDINATOR=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here

{
  "meta": {
    "lastTouchedVersion": "2026.3.3",
    "lastTouchedAt": "2026-03-05T19:45:25.186Z"
  },
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-6",
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "cacheRetention": "short"
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m"
      }
    },
    "list": [
      {
        "id": "operator_risk_agent",
        "default": true,
        "name": "Operator Risk",
        "model": "anthropic/claude-sonnet-4-6",
        "skills": [
          "gatekeeper",
          "macro_context_oracle"
        ],
        "identity": {
          "name": "OpenClaw Risk",
          "emoji": "🛡️"
        }
      },
      {
        "id": "research_agent",
        "name": "Research",
        "model": "anthropic/claude-sonnet-4-6",
        "skills": [
          "browser",
          "gatekeeper",
          "macro_context_oracle"
        ],
        "identity": {
          "name": "OpenClaw Research",
          "emoji": "🔍"
        }
      },
      {
        "id": "builder_agent",
        "name": "Builder",
        "model": "anthropic/claude-sonnet-4-6",
        "skills": [
          "github",
          "gatekeeper"
        ],
        "identity": {
          "name": "OpenClaw Builder",
          "emoji": "🔧"
        }
      }
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "operator_risk_agent",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "accounts": {
        "default": {
          "name": "openclaw-operator",
          "dmPolicy": "allowlist",
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "replyToMode": "first",
          "allowFrom": [
            7381250590
          ],
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://0.0.0.0:18789"
      ]
    },
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tls": {
      "enabled": false
    }
  },
  "skills": {
    "allowBundled": [
      "browser",
      "github"
    ],
    "load": {
      "extraDirs": [
        "/workspace/skills"
      ],
      "watch": false
    }
  }
}

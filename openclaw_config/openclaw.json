      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "30m"
      }
    },
    "list": [
      {
        "id": "operator_risk_agent",
        "default": true,
        "name": "Operator Risk",
        "model": "openai-codex/gpt-5.3-codex",
        "skills": [
          "gatekeeper",
          "macro_context_oracle"
        ],
        "identity": {
          "name": "OpenClaw Risk",
          "emoji": "\ud83d\udee1\ufe0f"
        }
      },
      {
        "id": "research_agent",
        "name": "Research",
        "model": "openai-codex/gpt-5.3-codex",
        "skills": [
          "browser",
          "gatekeeper",
          "macro_context_oracle"
        ],
        "identity": {
          "name": "OpenClaw Research",
          "emoji": "\ud83d\udd0d"
        }
      },
      {
        "id": "builder_agent",
        "name": "Builder",
        "model": "openai-codex/gpt-5.3-codex",
        "skills": [
          "github",
          "gatekeeper"
        ],
        "identity": {
          "name": "OpenClaw Builder",
          "emoji": "\ud83d\udd27"
        }
      }
    ]
  },
  "bindings": [
    {
      "type": "route",
      "agentId": "operator_risk_agent",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "accounts": {
        "default": {
          "name": "openclaw-operator",
          "dmPolicy": "allowlist",
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "replyToMode": "first",
          "allowFrom": [
            7381250590
          ],
          "groupPolicy": "allowlist",
          "streaming": "partial"
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://0.0.0.0:18789"
      ]
    },
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tls": {
      "enabled": false
    }
  },
  "skills": {
    "allowBundled": [
      "browser",
      "github"
